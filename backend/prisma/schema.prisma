// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  MEMBER
  TRAINER
  GYM
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  username String?  @unique
  password String
  role     Role     @default(MEMBER)
  gymId    Int?
  gym      Gym?     @relation("UserGym", fields: [gymId], references: [id])
}

model Gym {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  address  String   @unique
  openTime String?
  closeTime String?
  trainerRecommendation Boolean?
  area     Int?
  description String?
  users User[] @relation("UserGym")
}