generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int                 @id @default(autoincrement())
  password    String
  username    String?             @unique
  email       String              @unique
  gymId       Int?
  role        Role                @default(MEMBER)
  trainerGyms TrainerAssignment[]
  gym         Gym?                @relation("UserGym", fields: [gymId], references: [id])
}

model Gym {
  id                    Int                 @id @default(autoincrement())
  name                  String              @unique
  address               String              @unique
  openTime              String?
  closeTime             String?
  trainerRecommendation Boolean?
  area                  Int?
  description           String?
  inviteTrainers        GymInviteTrainer[]
  trainers              TrainerAssignment[]
  users                 User[]              @relation("UserGym")
}

model TrainerAssignment {
  id        Int      @id @default(autoincrement())
  trainerId Int
  gymId     Int
  createdAt DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer   User     @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, gymId])
  @@index([trainerId])
  @@index([gymId])
}

model GymInviteTrainer {
  id             Int      @id @default(autoincrement())
  gymId          Int
  hash           String   @unique @db.VarChar(128)
  expirationDate DateTime
  alreadyUsed    Boolean  @default(false)
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

enum Role {
  MEMBER
  TRAINER
  GYM
}
