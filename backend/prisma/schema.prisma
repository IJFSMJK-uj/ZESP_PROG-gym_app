generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int                 @id @default(autoincrement())
  password    String
  username    String?             @unique
  email       String              @unique
  gymId       Int?
  role        Role                @default(MEMBER)
  gym         Gym?                @relation("UserGym", fields: [gymId], references: [id])
  
  trainerGyms TrainerAssignment[]
  trainerAvailability TrainerAvailability[]
  trainerReservations TrainerReservation[] @relation("TrainerReservations")
  userReservations    TrainerReservation[] @relation("UserReservations")
  
}

model Gym {
  id                    Int                 @id @default(autoincrement())
  name                  String              @unique
  address               String              @unique
  openTime              String?
  closeTime             String?
  trainerRecommendation Boolean?
  area     Int?
  description String?
  users User[] @relation("UserGym")

  inviteTrainers  GymInviteTrainer[]
  trainers        TrainerAssignment[]
  availability TrainerAvailability[]
  trainerReservations TrainerReservation[]
}

model TrainerAssignment {
  id        Int      @id @default(autoincrement())
  trainerId Int
  gymId     Int
  createdAt DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer   User     @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, gymId])
  @@index([trainerId])
  @@index([gymId])
}

model GymInviteTrainer {
  id             Int      @id @default(autoincrement())
  gymId          Int
  hash           String   @unique @db.VarChar(128)
  expirationDate DateTime
  alreadyUsed    Boolean  @default(false)
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

model TrainerAvailability {
  id        Int @id @default(autoincrement())
  trainerId Int
  gymId     Int?

  dayOfWeek Int  // 0=Sunday, 1=Monday ... 6=Saturday
  startHour Int
  endHour   Int

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  gym     Gym?  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([trainerId, gymId])
  @@index([dayOfWeek])
}

model TrainerReservation {
  id        Int      @id @default(autoincrement())

  trainerId Int
  userId    Int
  gymId     Int?

  date      DateTime
  startHour Int
  endHour   Int

  status    ReservationStatus @default(CONFIRMED)

  cancelledByUser    Boolean @default(false)
  cancelledByTrainer Boolean @default(false)

  createdAt DateTime @default(now())

  trainer User @relation("TrainerReservations", fields: [trainerId], references: [id], onDelete: Cascade)
  user    User @relation("UserReservations", fields: [userId], references: [id], onDelete: Cascade)
  gym     Gym? @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([trainerId, date])
  @@index([userId])
}

enum Role {
  MEMBER
  TRAINER
  GYM
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
}